{
  "name": "ims-frontend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve ims-frontend --port 4200 --proxy-config proxy.conf.json",
    "start:dev": "ng serve ims-frontend --host 127.0.0.1 --port 4201 --proxy-config proxy.conf.json",
    "build": "ng build --configuration=production --base-href /SpringMVC_IMS/ --deploy-url /SpringMVC_IMS/",
    "deploy": "npm run build && npx cpy \"dist/**\" \"../core/src/main/webapp/\" --parents",
    "test": "ng test",
    "lint": "ng lint"
  },
  "dependencies": {
    "@angular/animations": "^21.2.5",
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/platform-browser": "^21.2.5",
    "@angular/platform-browser-dynamic": "^21.2.5",
    "@angular/router": "^21.2.5",
    "rxjs": "^7.8.0",
    "tslib": "^2.7.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.5",
    "cpy-cli": "^7.0.0",
    "typescript": "5.9.3"
  }
  ,
  "overrides": {
    "undici": "^7.24.0"
  }
}