{
  "name": "ims-frontend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve ims-frontend --port 4200 --proxy-config proxy.conf.json",
    "start:dev": "ng serve ims-frontend --host 127.0.0.1 --port 4201 --proxy-config proxy.conf.json",
    "build": "ng build --configuration=production --base-href /SpringMVC_IMS/ --deploy-url /SpringMVC_IMS/",
    "deploy": "npm run build && npx cpy \"dist/**\" \"../core/src/main/webapp/\" --parents",
    "test": "ng test",
    "lint": "ng lint"
  },
  "dependencies": {
    "@angular/animations": "^20.3.18",
    "@angular/common": "^20.3.18",
    "@angular/compiler": "^20.3.18",
    "@angular/core": "^20.3.18",
    "@angular/forms": "^20.3.18",
    "@angular/platform-browser": "^20.3.18",
    "@angular/platform-browser-dynamic": "^20.3.18",
    "@angular/router": "^20.3.18",
    "rxjs": "^7.8.0",
    "tslib": "^2.7.0",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular/build": "^20.3.21",
    "@angular/cli": "^20.3.21",
    "@angular/compiler-cli": "^20.3.18",
    "cpy-cli": "^3.1.1",
    "typescript": "5.8.3"
  }
}